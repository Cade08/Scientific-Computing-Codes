import numpy as np
import random

def f(x):
    return np.sin(x)

a = int(input("Enter lower bound: "))
b = int(input("Enter upper bound: "))
n = int(input("Enter number of iterations: "))

sum_fx = 0

for i in range(n):
    x = random.uniform(a, b)
    sum_fx += f(x)
    
final = (b-a)*(sum_fx / n)

print(round(final, 4))
